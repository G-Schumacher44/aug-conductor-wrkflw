# Copy to .env and fill in values — .env is gitignored, never commit it
# Source before running: source .env  (or use direnv)

# ── Google Developer Knowledge MCP ─────────────────────────────────────────
# Required for the google-developer-knowledge MCP server in .vscode/mcp.json
# 1. Enable the API: gcloud beta services mcp enable developerknowledge.googleapis.com --project=YOUR_PROJECT
# 2. Create a restricted API key in Google Cloud Console
# 3. Paste the key below
GOOGLE_DEV_KNOWLEDGE_API_KEY=your-api-key-here

# ── BigQuery MCP Toolbox ────────────────────────────────────────────────────
# No API key needed — uses Application Default Credentials (ADC)
# Run once: gcloud auth application-default login
# The BIGQUERY_PROJECT is set directly in .vscode/mcp.json
