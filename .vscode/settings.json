{
  // ── File watcher (prevents CPU spike on rapid agent writes) ──────────────
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.venv/**": true,
    "**/project/**": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/project": true
  },
  "git.autorefresh": false,

  // ── LookML ───────────────────────────────────────────────────────────────
  "files.associations": {
    "*.lkml": "lookml"
  },
  "[lookml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false
  },

  // ── Python (validate.py) ─────────────────────────────────────────────────
  "python.defaultInterpreterPath": "python3",

  // ── Looker extension — fill in after provisioning a Looker connection ────
  // Do NOT hardcode credentials here. Set via shell env vars
  // (LOOKER_INSTANCE_URL, LOOKER_CLIENT_ID, LOOKER_CLIENT_SECRET).
  //
  // "looker.instanceUrl": "https://your-instance.looker.com",
  // "looker.clientId": "",
  // "looker.clientSecret": ""
}
